# Public client-side Supabase values. These are safe to expose, but still keep
# real values out of git and configure them in Netlify instead.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side values used by TanStack Start server functions on Netlify.
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Secret. Never expose this in client code or commit it to git .
SUPABASE_SERVICE_ROLE_KEY=
